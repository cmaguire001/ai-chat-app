[nix]
channel = "stable-25_05"
packages = ["unzip", "nodejs_20"]

[agent]
expertMode = true

run = "npm install && npm run dev"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 3001
externalPort = 3001

[deployment]
run = ["sh", "-c", "npm install && npm run build && npm start"]
deploymentTarget = "cloudrun"
publicDir = "public"
